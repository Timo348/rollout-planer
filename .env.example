# production = ausschließlich Authentik; development erlaubt optional den Dev-Login.
APP_MODE=production
APP_BASE_URL=https://rollout.intern.example
APP_PORT=8080
APP_IMAGE_TAG=latest
HOST=0.0.0.0
PORT=8080
TRUST_PROXY=true

# Mindestens 32 zufällige Zeichen. Niemals den Beispielwert produktiv verwenden.
SESSION_SECRET=BITTE-DURCH-EINEN-LANGEN-ZUFAELLSWERT-ERSETZEN
SESSION_TTL_HOURS=12
SESSION_COOKIE_SECURE=true

# Vorhandener Authentik OAuth2/OIDC Provider
OIDC_ISSUER=https://authentik.intern.example/application/o/rollout-planer/
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Das Authentik-profile-Mapping muss `groups` als Liste im ID-Token liefern.
OIDC_SCOPES=openid profile email

# Wirkt nur zusammen mit APP_MODE=development.
DEV_LOGIN_ENABLED=false
DEV_LOGIN_NAME=Entwickler
DEV_LOGIN_USERNAME=dev

# Lokaler Administrator-Zugang mit Benutzername/Passwort (Standard: admin/admin).
# Unbedingt ein eigenes Passwort setzen oder per ADMIN_LOGIN_ENABLED=false deaktivieren.
ADMIN_LOGIN_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# PostgreSQL-Zugang für den Compose-Datenbankdienst.
POSTGRES_USER=rollout
POSTGRES_PASSWORD=BITTE-DURCH-EIN-SICHERES-PASSWORT-ERSETZEN
POSTGRES_DB=rollout

# Direkter Datenbank-DSN (nur für Betrieb ohne docker compose relevant;
# im Compose-Setup wird DATABASE_URL automatisch aus den POSTGRES_*-Werten gebaut).
DATABASE_URL=postgres://rollout:BITTE-DURCH-EIN-SICHERES-PASSWORT-ERSETZEN@db:5432/rollout

# Bestehender JSON-Bestand wird beim ersten Start automatisch in die Datenbank
# importiert und danach als rollout-state.json.migrated gesichert.
DATA_FILE=/app/data/rollout-state.json
STATIC_DIR=/app/dist/public
LOG_LEVEL=info

# Tägliche Termin-E-Mail um 07:00 Uhr (Europe/Berlin) mit iCal-Anhang an die
# in Authentik hinterlegte Mailadresse. Ohne SMTP_HOST bleibt der Versand deaktiviert.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=rollout-planer@example.com
